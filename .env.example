# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Add secrets to Trigger.dev dashboard for production:
#   https://cloud.trigger.dev → Project → Environment Variables
# ============================================================


# ------------------------------------------------------------
# Trigger.dev
# ------------------------------------------------------------
# Your project's secret key — found in the Trigger.dev dashboard
# under Project → API Keys → Secret Key
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------
# ClickUp
# ------------------------------------------------------------
# Personal API token — ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxx

# The numeric ID of the list that contains your research tasks.
# Find it in the URL when you open a ClickUp list:
#   https://app.clickup.com/{workspace}/v/li/{LIST_ID}
CLICKUP_LIST_ID=900000000000


# ------------------------------------------------------------
# AI / LLM — Unified via OpenRouter
#
# Sign up at https://openrouter.ai and create an API key.
# OpenRouter gives you access to GPT-4o, Claude, Mistral,
# Perplexity, and hundreds of other models under a single key.
#
# Already have an OpenAI key and don't want OpenRouter?
# Set OPENROUTER_BASE_URL=https://api.openai.com/v1 and use
# your OpenAI key as OPENROUTER_API_KEY. Note that the
# Perplexity research model won't work in that case — set
# OPENROUTER_RESEARCH_MODEL=gpt-4o instead.
# ------------------------------------------------------------

# Your OpenRouter API key (or OpenAI key — see note above)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# API base URL — change to https://api.openai.com/v1 for direct OpenAI
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model used for synthesis, book context, and digest generation
# OpenRouter model IDs: https://openrouter.ai/models
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Model used for web research (must support live browsing).
# perplexity/sonar has built-in internet access — no separate search API needed.
# If using direct OpenAI, set this to gpt-4o (no browsing, but still useful).
OPENROUTER_RESEARCH_MODEL=perplexity/sonar


# ------------------------------------------------------------
# Knowledge Base API
# ------------------------------------------------------------
# Self-hosted knowledge base — stores books and dream records
# with pgvector embeddings for semantic search.
KNOWLEDGE_BASE_BASE_URL=https://knowledgebase-api.alakad.de
KNOWLEDGE_BASE_API_KEY=


# ------------------------------------------------------------
# Dream Log (ClickUp)
# ------------------------------------------------------------
# Separate ClickUp list for dream journal entries.
# Create a list called "Dream Log" with statuses:
#   Raw → Processing → Done / Error
# Find the ID in the URL: https://app.clickup.com/{workspace}/v/li/{LIST_ID}
CLICKUP_DREAM_LIST_ID=900000000000


# ------------------------------------------------------------
# Dream Log — Models
# ------------------------------------------------------------
# Model for cleaning raw dream text and extracting structured JSON
# (title, themes, symbols, emotional tone, day_residue).
# V4-Flash is sufficient — this is extraction, not reasoning.
DREAM_CLEANER_MODEL=deepseek/deepseek-v4-flash

# Model for HyDE (Hypothetical Document Embeddings) — generates
# short hypothetical Jungian textbook passages for KB retrieval.
# V4-Flash is sufficient — short passage generation, no reasoning.
DREAM_HYDE_MODEL=deepseek/deepseek-v4-flash

# Model for scholarly web research (must support live browsing).
DREAM_RESEARCHER_MODEL=perplexity/sonar

# Model for final Jungian synthesis and interpretation.
# R1 is recommended — this is the hardest reasoning task in the pipeline
# (dramatic structure, 7 Jungian principles, symbol grounding).
# Cost difference vs V4-Flash is ~$0.0005 per dream — negligible.
DREAM_SYNTHESIZER_MODEL=deepseek/deepseek-r1
