# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# Add secrets to Trigger.dev dashboard for production:
#   https://cloud.trigger.dev → Project → Environment Variables
# ============================================================


# ------------------------------------------------------------
# Trigger.dev
# ------------------------------------------------------------
# Your project's secret key — found in the Trigger.dev dashboard
# under Project → API Keys → Secret Key
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxxxxxx


# ------------------------------------------------------------
# Note Provider
# ------------------------------------------------------------
# Controls which app the automations read from and write to.
# Set to "clickup" or "notion". Default: clickup.
NOTE_PROVIDER=notion


# ------------------------------------------------------------
# ClickUp  (required when NOTE_PROVIDER=clickup)
# ------------------------------------------------------------
# Personal API token — ClickUp → Settings → Apps → API Token
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxx

# Separate list for Dream Log entries.
# Statuses required: Raw · Processing · Done · Error
# Optional custom field: "dayResidue" (text)
CLICKUP_DREAM_LIST_ID=900000000001


# ------------------------------------------------------------
# Notion  (required when NOTE_PROVIDER=notion)
# ------------------------------------------------------------
# Integration secret — notion.com/my-integrations → your integration → show token
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx

# Database for Dream Log entries.
# Properties required: Status (select: Raw · Processing · Done · Error)
# Optional property: "Day Residue" (text)
# Content goes in the page body, not a property.
NOTION_DREAM_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx


# ------------------------------------------------------------
# AI / LLM — Unified via OpenRouter
#
# Sign up at https://openrouter.ai and create an API key.
# OpenRouter gives you access to GPT-4o, Claude, Mistral,
# Perplexity, and hundreds of other models under a single key.
#
# Already have an OpenAI key and don't want OpenRouter?
# Set OPENROUTER_BASE_URL=https://api.openai.com/v1 and use
# your OpenAI key as OPENROUTER_API_KEY. Note that the
# Perplexity research model won't work in that case — set
# OPENROUTER_RESEARCH_MODEL=gpt-4o instead.
# ------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1


# ------------------------------------------------------------
# Knowledge Base API
# ------------------------------------------------------------
# Self-hosted knowledge base — stores books and dream records
# with pgvector embeddings for semantic search.
KNOWLEDGE_BASE_BASE_URL=https://knowledgebase-api.alakad.de
KNOWLEDGE_BASE_API_KEY=


# ------------------------------------------------------------
# Kleinanzeigen GPU Scout
# ------------------------------------------------------------
# Self-hosted Kleinanzeigen scraper API.
KLEINANZEIGEN_API_URL=http://192.168.178.40:8001
KLEINANZEIGEN_API_TOKEN=your-api-token-here

# ntfy.sh push notifications (recommended — free, works offline, tap → opens listing).
# Setup: install ntfy app → subscribe to your topic name → paste it here.
# Public server: https://ntfy.sh  (hosted, no account needed)
# Self-hosted:   set KLEINANZEIGEN_NTFY_URL to your own ntfy instance URL
# If not set, results are only visible in the Trigger.dev run logs.
KLEINANZEIGEN_NTFY_TOPIC=your-topic-name
KLEINANZEIGEN_NTFY_URL=https://ntfy.sh


# ------------------------------------------------------------
# Dream Log — Models
# ------------------------------------------------------------
# Cleans raw dream text and extracts structured JSON
# (title, themes, symbols, emotional tone, day_residue).
DREAM_CLEANER_MODEL=deepseek/deepseek-v3.2

# HyDE model — generates short hypothetical Jungian passages for KB retrieval.
DREAM_HYDE_MODEL=deepseek/deepseek-v4-flash

# Scholarly web research — must support live browsing.
DREAM_RESEARCHER_MODEL=perplexity/sonar

# Final Jungian synthesis and interpretation.
# R1 recommended — hardest reasoning task in the pipeline.
DREAM_SYNTHESIZER_MODEL=deepseek/deepseek-r1
