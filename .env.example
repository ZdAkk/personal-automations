# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# In production, set these in the Trigger.dev dashboard
# (Project → Environment Variables) — EXCEPT TRIGGER_SECRET_KEY,
# which the platform provides automatically.
# ============================================================


# ============================================================
# SHARED INFRASTRUCTURE  (used by multiple automations)
# ============================================================

# --- Trigger.dev ---------------------------------------------
# Secret key — Trigger.dev dashboard → Project → API Keys → Secret Key.
# Local/dev only; in prod the platform injects it (do NOT add it to the
# dashboard env vars).
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxxxxxxxxxx
# Deploy target — set these so you never pass --project-ref / --profile on the
# CLI. TRIGGER_PROJECT_REF is read by trigger.config.ts. For a self-hosted
# instance, TRIGGER_API_URL + TRIGGER_ACCESS_TOKEN (a Personal Access Token from
# the instance dashboard) tell the CLI which instance/account to target.
TRIGGER_PROJECT_REF=proj_xxxxxxxxxxxxxxxxxxxx
TRIGGER_API_URL=https://your-self-hosted-trigger.example.com
TRIGGER_ACCESS_TOKEN=tr_pat_xxxxxxxxxxxxxxxxxxxx

# --- AI / LLM — OpenRouter -----------------------------------
# One key for every LLM call (GPT, Claude, DeepSeek, Perplexity, …).
# To use OpenAI directly: set OPENROUTER_BASE_URL=https://api.openai.com/v1
# and put your OpenAI key in OPENROUTER_API_KEY.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- ntfy push notifications ---------------------------------
# Used by the GPU Scout (the apartment scouts email instead — see Resend below).
# NTFY_URL is REQUIRED (no default — publishing throws if unset, so private
# alerts can't silently leak to a public server). Public server: https://ntfy.sh.
NTFY_URL=https://ntfy.sh
# Account used to publish to any topic. Blank only for a public (no-auth) server;
# required for a protected (deny-all) server.
NTFY_USER=
NTFY_PASSWORD=

# --- Resend email (apartment digests) ------------------------
# Both apartment scouts send ONE digest email per poll via Resend instead of
# per-listing push. RESEND_API_KEY from resend.com → API Keys. EMAIL_FROM must
# be on a Resend-VERIFIED domain; EMAIL_TO is where the digests go.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=wohnung-scout@yourdomain.tld
EMAIL_TO=you@yourdomain.tld

# --- Kleinanzeigen scraper API -------------------------------
# Self-hosted scraper. SHARED by the GPU Scout and the Wohnung Scout.
KLEINANZEIGEN_API_URL=http://192.168.178.40:8001
KLEINANZEIGEN_API_TOKEN=your-api-token-here


# ============================================================
# AUTOMATIONS
# ============================================================

# --- GPU Scout  (Kleinanzeigen GPU deals) --------------------
# ntfy topic the GPU watcher publishes to (subscribe to it in the ntfy app).
# Per-watch overrides via the watch's notify.topicEnv.
GPU_NTFY_TOPIC=your-gpu-topic

# --- Wohnung Scout  (Kleinanzeigen apartments) ---------------
# Matches are emailed as one digest per poll (Resend, see EMAIL_* above). Search
# params live in src/config/wohnung-watches.ts.
# Model for the one-sentence personalised hook (used by BOTH apartment pipelines).
# Defaults to anthropic/claude-sonnet-4. It's one short sentence per listing, so
# cost is negligible even on a premium model; swap for a cheaper one if desired.
WOHNUNG_LLM_MODEL=anthropic/claude-sonnet-4

# --- ImmoScout Scout  (ImmoScout24 apartments, mobile JSON API) ---
# Pure HTTP against api.mobile.immobilienscout24.de — no scraper box, no captcha.
# Matches are emailed (Resend, see EMAIL_* above); reuses OpenRouter +
# WOHNUNG_LLM_MODEL for the drafted hook.
# The IS24 app User-Agent the mobile API expects. Bump the version if the API
# starts returning empty results (it tracks the shipping app).
IMMOSCOUT_USER_AGENT=ImmoScout_27.12_26.2_._

# --- Dream Log -----------------------------------------------
# Which app the Dream Log reads from / writes to: "clickup" or "notion".
NOTE_PROVIDER=notion

# ClickUp (required when NOTE_PROVIDER=clickup)
# Token: ClickUp → Settings → Apps → API Token.
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxx
# Dream Log list. Statuses: Raw · Processing · Done · Error. Optional field: dayResidue.
CLICKUP_DREAM_LIST_ID=900000000001

# Notion (required when NOTE_PROVIDER=notion)
# Integration secret — notion.com/my-integrations → your integration → show token.
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxx
# Dream Log database. Property: Status (select: Raw · Processing · Done · Error).
# Optional property: "Day Residue". Content goes in the page body.
NOTION_DREAM_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Knowledge Base API — self-hosted, stores books + dream records (pgvector search).
KNOWLEDGE_BASE_BASE_URL=https://knowledgebase-api.alakad.de
KNOWLEDGE_BASE_API_KEY=

# Models (per pipeline step)
DREAM_CLEANER_MODEL=deepseek/deepseek-v3.2       # clean raw text -> structured JSON
DREAM_HYDE_MODEL=deepseek/deepseek-v4-flash       # hypothetical passages for KB retrieval
DREAM_RESEARCHER_MODEL=perplexity/sonar           # scholarly web research (needs live browsing)
DREAM_SYNTHESIZER_MODEL=deepseek/deepseek-r1      # final Jungian synthesis (hardest reasoning)
